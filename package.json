{
  "name": "Mark",
  "version": "1.0.0",
  "description": "Mark en mi escritorio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-packager . MarkPet --platform=win32 --arch=x64 --icon=Icon.ico --overwrite",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.mark.app",
    "productName": "MarkPet",
    "win": {
      "target": "portable",
      "icon": "Icon.ico"
    },
    "directories": {
      "output": "dist"
    }
  }
}